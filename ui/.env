# Thesa UI Environment Configuration
# Copy to .env.local for local overrides (git-ignored)

# BFF Base URL
BFF_BASE_URL=http://localhost:8080

# OIDC Configuration (Ory Hydra)
# Redirect URIs are handled automatically per platform:
#   Mobile: org.stawi.thesa://sso/redirect (custom URL scheme)
#   Desktop: http://localhost:5170 (loopback server)
#   Web: current page URL (redirect flow)
OIDC_ISSUER=https://oauth2.stawi.org
OIDC_CLIENT_ID=d6qbqdkpf2t52mcunf3g
OIDC_SCOPES=openid,profile,contact,offline_access
